{
  "name": "karnataka-study-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "start:mobile": "npm run start --workspace=apps/mobile",
    "build:shared": "npm run build --workspace=packages/shared",
    "install:all": "npm install"
  }
}
